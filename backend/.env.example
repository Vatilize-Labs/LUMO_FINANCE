# Server
PORT=8000
ENVIRONMENT=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=lumo_finance

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your_jwt_secret_key_here

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Nomba API
NOMBA_API_KEY=your_nomba_api_key
NOMBA_BASE_URL=https://api.nomba.com/v1
# sandbox = deterministic fake Nomba client (no network, no credentials needed)
# live = real Nomba API calls using NOMBA_API_KEY
NOMBA_MODE=sandbox

# Claude API (AI chat with tool calling)
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-5
